---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>

	<!-- ── Hero ─────────────────────────────────────────────────── -->
	<section class="hero">
		<div class="hero-pattern" aria-hidden="true"></div>
		<div class="container hero-content">
			<span class="section-eyebrow">Private Equity · Central Asia</span>
			<h1>Unlocking Long-Term Value Across Central Asia</h1>
			<hr class="divider" />
			<p class="hero-subtitle">
				Venera Capital is a private equity firm dedicated to identifying and building exceptional businesses across Kazakhstan, Uzbekistan, and the broader Central Asian region.
			</p>
			<div class="hero-actions">
				<a href="/focus"   class="btn btn-primary">Investment Focus</a>
				<a href="/about"   class="btn btn-outline">About the Firm</a>
			</div>
		</div>
		<div class="hero-scroll" aria-hidden="true">
			<span>Scroll</span>
			<div class="scroll-line"></div>
		</div>
	</section>

	<!-- ── Highlights bar ────────────────────────────────────────── -->
	<section class="section-sm bg-off-white">
		<div class="container">
			<div class="highlights">
				<div class="hl-item">
					<span class="hl-label">Region</span>
					<span class="hl-value">Central Asia</span>
				</div>
				<div class="hl-sep" aria-hidden="true"></div>
				<div class="hl-item">
					<span class="hl-label">Strategy</span>
					<span class="hl-value">Multi-Sector</span>
				</div>
				<div class="hl-sep" aria-hidden="true"></div>
				<div class="hl-item">
					<span class="hl-label">Approach</span>
					<span class="hl-value">Long-Term Partnership</span>
				</div>
				<div class="hl-sep" aria-hidden="true"></div>
				<div class="hl-item">
					<span class="hl-label">Focus</span>
					<span class="hl-value">Value Creation</span>
				</div>
			</div>
		</div>
	</section>

	<!-- ── About brief ───────────────────────────────────────────── -->
	<section class="section bg-white">
		<div class="container">
			<div class="about-grid">
				<div class="about-text">
					<span class="section-eyebrow">About Venera Capital</span>
					<h2>A Principled Approach to Private Equity in Central Asia</h2>
					<hr class="divider" />
					<p>
						Venera Capital brings together investment professionals with deep expertise in Central Asian markets and global private equity discipline. We partner with management teams to build businesses of lasting value.
					</p>
					<p style="color: var(--text-mid);">
						Our firm combines rigorous financial analysis with on-the-ground regional knowledge, enabling us to identify opportunities and navigate complexities that others may overlook.
					</p>
					<a href="/about" class="btn btn-outline-dark" style="margin-top:1rem;">Learn About the Firm</a>
				</div>
				<div class="principles">
					<div class="principle">
						<div class="p-num">01</div>
						<div>
							<h4>Long-Term Perspective</h4>
							<p>We invest with a multi-year horizon, focusing on sustainable growth over short-term financial engineering.</p>
						</div>
					</div>
					<div class="principle">
						<div class="p-num">02</div>
						<div>
							<h4>Operational Expertise</h4>
							<p>We work closely with portfolio companies to drive operational improvements and strategic value creation.</p>
						</div>
					</div>
					<div class="principle">
						<div class="p-num">03</div>
						<div>
							<h4>Regional Knowledge</h4>
							<p>Deep understanding of Central Asian markets provides a distinct and durable competitive advantage.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ── Sectors ───────────────────────────────────────────────── -->
	<section class="section bg-off-white">
		<div class="container">
			<div class="section-header-centered">
				<span class="section-eyebrow">Investment Focus</span>
				<h2>Key Sectors</h2>
				<hr class="divider divider-center" />
				<p class="section-intro">
					We invest across a range of sectors where we have deep expertise and where Central Asia presents compelling structural opportunities.
				</p>
			</div>
			<div class="sectors-grid">
				<div class="sector-card">
					<div class="s-icon">
						<svg width="30" height="30" viewBox="0 0 30 30" fill="none" aria-hidden="true">
							<path d="M15 3L27 9.5V20.5L15 27L3 20.5V9.5L15 3Z" stroke="currentColor" stroke-width="1.4" fill="none"/>
							<path d="M15 9.5V20.5M9.5 13L20.5 17" stroke="currentColor" stroke-width="1.4"/>
						</svg>
					</div>
					<h4>Energy & Natural Resources</h4>
					<p>Oil, gas, renewables, and natural resource investments driving the region's economic backbone.</p>
				</div>
				<div class="sector-card">
					<div class="s-icon">
						<svg width="30" height="30" viewBox="0 0 30 30" fill="none" aria-hidden="true">
							<rect x="3" y="8" width="24" height="15" rx="2" stroke="currentColor" stroke-width="1.4" fill="none"/>
							<path d="M9 15h12M9 19h8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
							<circle cx="23" cy="10" r="2.5" fill="currentColor" opacity="0.45"/>
						</svg>
					</div>
					<h4>Technology & Digital</h4>
					<p>Technology companies, digital infrastructure, fintech, and e-commerce transforming Central Asian economies.</p>
				</div>
				<div class="sector-card">
					<div class="s-icon">
						<svg width="30" height="30" viewBox="0 0 30 30" fill="none" aria-hidden="true">
							<path d="M3 27V13L15 5L27 13V27H19V19H11V27H3Z" stroke="currentColor" stroke-width="1.4" fill="none"/>
						</svg>
					</div>
					<h4>Real Estate</h4>
					<p>Commercial, residential, and mixed-use development in key urban centres across the region.</p>
				</div>
				<div class="sector-card">
					<div class="s-icon">
						<svg width="30" height="30" viewBox="0 0 30 30" fill="none" aria-hidden="true">
							<path d="M3 19C3 19 7 13 15 13C23 13 27 19 27 19" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/>
							<circle cx="15" cy="21" r="4" stroke="currentColor" stroke-width="1.4" fill="none"/>
							<path d="M15 5V9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
							<path d="M5 9L7.5 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
							<path d="M25 9L22.5 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
						</svg>
					</div>
					<h4>Infrastructure</h4>
					<p>Transport networks, logistics hubs, utilities, and essential infrastructure underpinning regional growth.</p>
				</div>
				<div class="sector-card">
					<div class="s-icon">
						<svg width="30" height="30" viewBox="0 0 30 30" fill="none" aria-hidden="true">
							<rect x="3" y="9" width="24" height="16" rx="2" stroke="currentColor" stroke-width="1.4" fill="none"/>
							<path d="M9 9V7C9 5.9 9.9 5 11 5H19C20.1 5 21 5.9 21 7V9" stroke="currentColor" stroke-width="1.4" fill="none"/>
							<path d="M3 17H27" stroke="currentColor" stroke-width="1.4"/>
							<path d="M12 17V21M18 17V21" stroke="currentColor" stroke-width="1.4"/>
						</svg>
					</div>
					<h4>Financial Services</h4>
					<p>Banking, insurance, microfinance, and capital markets serving Central Asia's growing economy.</p>
				</div>
				<div class="sector-card">
					<div class="s-icon">
						<svg width="30" height="30" viewBox="0 0 30 30" fill="none" aria-hidden="true">
							<path d="M5 26V12L15 5L25 12V26" stroke="currentColor" stroke-width="1.4" fill="none"/>
							<path d="M11 26V19H19V26" stroke="currentColor" stroke-width="1.4" fill="none"/>
							<circle cx="15" cy="13" r="3" stroke="currentColor" stroke-width="1.4" fill="none"/>
						</svg>
					</div>
					<h4>Consumer & Retail</h4>
					<p>Consumer brands, food & beverage, and retail businesses capturing the region's rising middle class.</p>
				</div>
			</div>
			<div class="text-center" style="margin-top:3rem;">
				<a href="/focus" class="btn btn-outline-dark">Explore Our Focus Areas</a>
			</div>
		</div>
	</section>

	<!-- ── Philosophy ────────────────────────────────────────────── -->
	<section class="section bg-navy">
		<div class="container">
			<div class="philosophy-grid">
				<div class="phil-text">
					<span class="section-eyebrow">Our Approach</span>
					<h2 style="color:var(--white); font-weight:300;">Building Value Through Partnership</h2>
					<hr class="divider" />
					<p style="color:rgba(255,255,255,0.65);">
						At Venera Capital, exceptional returns are built through genuine partnership with management teams, deep sectoral expertise, and a long-term investment horizon. We are not passive investors — we work alongside our portfolio companies at every stage of their growth.
					</p>
					<a href="/about" class="btn btn-primary" style="margin-top:1.5rem;">Our Investment Philosophy</a>
				</div>
				<div class="phil-stats">
					<div class="stat">
						<span class="stat-val">Central Asia</span>
						<span class="stat-lbl">Primary Investment Region</span>
					</div>
					<div class="stat">
						<span class="stat-val">6+</span>
						<span class="stat-lbl">Core Investment Sectors</span>
					</div>
					<div class="stat">
						<span class="stat-val">Long-Term</span>
						<span class="stat-lbl">Investment Horizon</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ── CTA ───────────────────────────────────────────────────── -->
	<section class="section-sm bg-white">
		<div class="container">
			<div class="cta-box">
				<div class="cta-content">
					<h3>Interested in Working with Venera Capital?</h3>
					<p>Whether you are a potential investor, management team, or business partner, we welcome the opportunity to connect.</p>
				</div>
				<div class="cta-action">
					<a href="/contact" class="btn btn-primary">Get in Touch</a>
				</div>
			</div>
		</div>
	</section>

</Layout>

<style>
	/* Hero */
	.hero {
		background-color: var(--navy);
		min-height: calc(100vh - var(--header-height));
		display: flex;
		align-items: center;
		position: relative;
		overflow: hidden;
	}

	.hero-pattern {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(201,168,76,0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(201,168,76,0.04) 1px, transparent 1px);
		background-size: 64px 64px;
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		z-index: 1;
		padding-top: 4rem;
		padding-bottom: 4rem;
		max-width: 820px;
	}

	.hero h1 {
		color: var(--white);
		font-weight: 300;
		letter-spacing: -0.01em;
		margin-bottom: 0;
	}

	.hero .divider { margin: 2rem 0; }

	.hero-subtitle {
		font-size: 1.05rem;
		color: rgba(255,255,255,0.62);
		max-width: 540px;
		line-height: 1.85;
		margin-bottom: 2.5rem;
	}

	.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

	.hero-scroll {
		position: absolute;
		bottom: 2.5rem;
		left: 2rem;
		display: flex;
		align-items: center;
		gap: 1rem;
		color: rgba(255,255,255,0.35);
		font-size: 0.62rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}
	.scroll-line {
		width: 40px;
		height: 1px;
		background: rgba(255,255,255,0.25);
	}

	/* Highlights */
	.highlights {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hl-item {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		padding: 1.5rem 3rem;
		text-align: center;
	}

	.hl-label {
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.hl-value {
		font-family: var(--font-serif);
		font-size: 1.35rem;
		font-weight: 500;
		color: var(--text-dark);
		white-space: nowrap;
	}

	.hl-sep {
		width: 1px;
		height: 44px;
		background: var(--border);
		flex-shrink: 0;
	}

	/* About */
	.about-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		align-items: start;
	}

	.about-text h2 { margin-bottom: 0; }
	.about-text p  { color: var(--text-mid); font-size: 0.97rem; }

	.principles {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding-top: 0.25rem;
	}

	.principle {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
	}

	.p-num {
		font-family: var(--font-serif);
		font-size: 2rem;
		font-weight: 300;
		color: var(--gold);
		opacity: 0.55;
		line-height: 1;
		flex-shrink: 0;
		width: 38px;
	}

	.principle h4 {
		font-family: var(--font-sans);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		margin-bottom: 0.35rem;
		color: var(--text-dark);
	}

	.principle p {
		margin: 0;
		font-size: 0.88rem;
		color: var(--text-mid);
		line-height: 1.65;
	}

	/* Sectors */
	.sectors-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5px;
		background: var(--border);
		border: 1.5px solid var(--border);
	}

	.sector-card {
		background: var(--off-white);
		padding: 2.5rem 2rem;
		transition: background var(--transition);
	}

	.sector-card:hover { background: var(--white); }

	.s-icon {
		color: var(--gold);
		margin-bottom: 1.25rem;
	}

	.sector-card h4 {
		font-family: var(--font-sans);
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		margin-bottom: 0.65rem;
		color: var(--text-dark);
	}

	.sector-card p {
		font-size: 0.875rem;
		color: var(--text-mid);
		line-height: 1.65;
		margin: 0;
	}

	/* Philosophy */
	.philosophy-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		align-items: center;
	}

	.phil-stats {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		border-left: 1px solid rgba(255,255,255,0.1);
		padding-left: 4rem;
	}

	.stat { display: flex; flex-direction: column; gap: 0.4rem; }

	.stat-val {
		font-family: var(--font-serif);
		font-size: 2rem;
		font-weight: 400;
		color: var(--white);
		line-height: 1;
	}

	.stat-lbl {
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(255,255,255,0.38);
	}

	/* CTA */
	.cta-box {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 3rem;
		padding: 3.5rem 4rem;
		border: 1px solid var(--border);
	}

	.cta-content h3 { font-size: 1.7rem; margin-bottom: 0.65rem; }
	.cta-content p  { margin: 0; color: var(--text-mid); font-size: 0.95rem; }
	.cta-action     { flex-shrink: 0; }

	/* Responsive */
	@media (max-width: 900px) {
		.about-grid,
		.philosophy-grid   { grid-template-columns: 1fr; gap: 3rem; }
		.sectors-grid      { grid-template-columns: repeat(2,1fr); }
		.phil-stats {
			border-left: none;
			padding-left: 0;
			border-top: 1px solid rgba(255,255,255,0.1);
			padding-top: 2.5rem;
			flex-direction: row;
			flex-wrap: wrap;
			gap: 2rem;
		}
		.stat { flex: 1; min-width: 120px; }
		.cta-box { flex-direction: column; text-align: center; padding: 3rem 2rem; }
	}

	@media (max-width: 600px) {
		.highlights  { flex-wrap: wrap; }
		.hl-item     { padding: 1rem 1.5rem; width: 50%; }
		.hl-sep:nth-child(4) { display: none; }
		.sectors-grid { grid-template-columns: 1fr; }
		.hero-scroll  { display: none; }
	}
</style>
